{
  "manifest_version": 3,
  "name": "Emy",
  "version": "1.1.1",
  "description": "Silently block ads on YouTube, bypassing anti-adblock detection. Lightweight, fast, invisible.",
  "author": "Antonio (anto0102)",
  "permissions": [
    "declarativeNetRequest",
    "scripting",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "static_rules",
        "enabled": true,
        "path": "filters/rules_static.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Emy - YouTube ad blocker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  }
}
